<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.*?>
<?import java.net.URL?>

<AnchorPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllers.ModifierEventController">
    <stylesheets>
        <URL value="@styles.css" />
    </stylesheets>
    <children>
        <ScrollPane fitToWidth="true" fitToHeight="true" AnchorPane.topAnchor="0" AnchorPane.rightAnchor="0"
                    AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" styleClass="custom-scroll-pane" hbarPolicy="NEVER">
            <content>
                <VBox alignment="TOP_CENTER" spacing="15" styleClass="main-container">
                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20" />
                    </padding>

                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <Label text="Modifier un Événement" styleClass="header-label" />
                        <Button fx:id="annulerBtn" text="Annuler" onAction="#retourAListe" styleClass="cancel-button" />
                    </HBox>
                    <Separator styleClass="custom-separator" />
                    <GridPane hgap="10" vgap="10" alignment="CENTER" styleClass="form-grid">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="30" />
                            <ColumnConstraints percentWidth="70" />
                        </columnConstraints>
                        <rowConstraints>
                            <RowConstraints vgrow="SOMETIMES" />
                            <RowConstraints vgrow="SOMETIMES" />
                            <RowConstraints vgrow="SOMETIMES" />
                            <RowConstraints vgrow="SOMETIMES" />
                            <RowConstraints vgrow="SOMETIMES" />
                            <RowConstraints vgrow="SOMETIMES" />
                            <RowConstraints vgrow="SOMETIMES" />
                            <RowConstraints vgrow="SOMETIMES" />
                            <RowConstraints vgrow="SOMETIMES" />
                            <RowConstraints vgrow="SOMETIMES" />
                            <RowConstraints vgrow="SOMETIMES" />
                            <RowConstraints vgrow="SOMETIMES" />
                        </rowConstraints>

                        <!-- Titre -->
                        <Label text="Titre :" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="form-label" />
                        <TextField fx:id="titreTF" GridPane.rowIndex="0" GridPane.columnIndex="1" styleClass="text-input" />

                        <!-- Description -->
                        <Label text="Description :" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="form-label" />
                        <TextArea fx:id="descriptionTA" prefHeight="100" prefWidth="400" GridPane.rowIndex="1" GridPane.columnIndex="1" styleClass="text-input" />

                        <!-- Date Début -->
                        <Label text="Date Début :" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="form-label" />
                        <HBox spacing="5" GridPane.rowIndex="2" GridPane.columnIndex="1">
                            <DatePicker fx:id="dateDebutPicker" styleClass="date-input" />
                            <Spinner fx:id="heureDebutSpinner" editable="true" prefWidth="60" styleClass="time-input" />
                            <Label text=":" styleClass="time-separator" />
                            <Spinner fx:id="minuteDebutSpinner" editable="true" prefWidth="60" styleClass="time-input" />
                        </HBox>

                        <!-- Date Fin -->
                        <Label text="Date Fin :" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="form-label" />
                        <HBox spacing="5" GridPane.rowIndex="3" GridPane.columnIndex="1">
                            <DatePicker fx:id="dateFinPicker" styleClass="date-input" />
                            <Spinner fx:id="heureFinSpinner" editable="true" prefWidth="60" styleClass="time-input" />
                            <Label text=":" styleClass="time-separator" />
                            <Spinner fx:id="minuteFinSpinner" editable="true" prefWidth="60" styleClass="time-input" />
                        </HBox>

                        <!-- Organisateur -->
                        <Label text="Organisateur :" GridPane.rowIndex="4" GridPane.columnIndex="0" styleClass="form-label" />
                        <ComboBox fx:id="organisateurComboBox" GridPane.rowIndex="4" GridPane.columnIndex="1" styleClass="combo-input" />

                        <!-- Carte Interactive -->
                        <Label text="Carte :" GridPane.rowIndex="5" GridPane.columnIndex="0" styleClass="form-label" />
                        <VBox GridPane.rowIndex="5" GridPane.columnIndex="1">
                            <WebView fx:id="mapWebView" prefHeight="200" prefWidth="400" minHeight="200" minWidth="400" styleClass="map-view" />
                            <HBox spacing="5" alignment="CENTER" styleClass="map-controls">
                                <Button fx:id="zoomInBtn" text="+" styleClass="map-button" />
                                <Button fx:id="zoomOutBtn" text="-" styleClass="map-button" />
                                <Button fx:id="myLocationBtn" text="Ma Position" styleClass="location-button" />
                            </HBox>
                        </VBox>

                        <!-- Adresse -->
                        <Label text="Adresse :" GridPane.rowIndex="6" GridPane.columnIndex="0" styleClass="form-label" />
                        <TextField fx:id="adresseField" GridPane.rowIndex="6" GridPane.columnIndex="1" styleClass="text-input" />

                        <!-- Coordonnées -->
                        <Label text="Latitude :" GridPane.rowIndex="7" GridPane.columnIndex="0" styleClass="form-label" />
                        <TextField fx:id="latitudeField" GridPane.rowIndex="7" GridPane.columnIndex="1" styleClass="text-input" />
                        <Label text="Longitude :" GridPane.rowIndex="8" GridPane.columnIndex="0" styleClass="form-label" />
                        <TextField fx:id="longitudeField" GridPane.rowIndex="8" GridPane.columnIndex="1" styleClass="text-input" />

                        <!-- Capacité -->
                        <Label text="Capacité :" GridPane.rowIndex="9" GridPane.columnIndex="0" styleClass="form-label" />
                        <Spinner fx:id="capaciteSpinner" editable="true" prefWidth="100" GridPane.rowIndex="9" GridPane.columnIndex="1" styleClass="spinner-input" />

                        <!-- Catégorie -->
                        <Label text="Catégorie :" GridPane.rowIndex="10" GridPane.columnIndex="0" styleClass="form-label" />
                        <ComboBox fx:id="categorieComboBox" GridPane.rowIndex="10" GridPane.columnIndex="1" styleClass="combo-input" />

                        <!-- Visibilité -->
                        <Label text="Visibilité :" GridPane.rowIndex="11" GridPane.columnIndex="0" styleClass="form-label" />
                        <HBox spacing="10" GridPane.rowIndex="11" GridPane.columnIndex="1" styleClass="radio-group">
                            <RadioButton fx:id="publicRadio" text="Public" toggleGroup="$visibilityGroup" selected="true" styleClass="radio-option" />
                            <RadioButton fx:id="priveRadio" text="Privé" toggleGroup="$visibiliteGroup" styleClass="radio-option" />
                        </HBox>

                        <!-- Durée -->
                        <Label text="Durée :" GridPane.rowIndex="12" GridPane.columnIndex="0" styleClass="form-label" />
                        <Label fx:id="dureeLabel" text="Calculée automatiquement" GridPane.rowIndex="12" GridPane.columnIndex="1" styleClass="info-label" />
                    </GridPane>

                    <!-- Bouton de soumission -->
                    <HBox alignment="CENTER" spacing="20" styleClass="button-bar">
                        <Button text="Enregistrer" onAction="#modifierEvenement" styleClass="add-button" />
                    </HBox>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>