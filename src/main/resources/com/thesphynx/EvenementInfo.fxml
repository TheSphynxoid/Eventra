<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.*?>
<?import java.net.URL?>

<AnchorPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.thesphynx.controllers.EventControllerInfo">
    <stylesheets>
        <URL value="@styles.css" />
    </stylesheets>
    <children>
        <ScrollPane fitToWidth="true" fitToHeight="true" AnchorPane.topAnchor="0" AnchorPane.rightAnchor="0"
                    AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" styleClass="custom-scroll-pane" hbarPolicy="NEVER">
            <content>
                <VBox alignment="TOP_CENTER" spacing="15" styleClass="main-container">
                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20" />
                    </padding>

                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <Label text="Détails de l'Événement" styleClass="header-label" />
                        <Button fx:id="retourBtn" text="Retour" onAction="#retour" styleClass="cancel-button" />
                    </HBox>
                    <Separator styleClass="custom-separator" />
                    <GridPane hgap="10" vgap="10" alignment="CENTER" styleClass="form-grid">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="30" />
                            <ColumnConstraints percentWidth="70" />
                        </columnConstraints>
                        <rowConstraints>
                            <RowConstraints vgrow="SOMETIMES" />
                            <RowConstraints vgrow="SOMETIMES" />
                            <RowConstraints vgrow="SOMETIMES" />
                            <RowConstraints vgrow="SOMETIMES" />
                            <RowConstraints vgrow="SOMETIMES" />
                            <RowConstraints vgrow="SOMETIMES" />
                            <RowConstraints vgrow="SOMETIMES" />
                            <RowConstraints vgrow="SOMETIMES" />
                            <RowConstraints vgrow="SOMETIMES" />
                            <RowConstraints vgrow="SOMETIMES" />
                            <RowConstraints vgrow="SOMETIMES" />
                        </rowConstraints>

                        <!-- Titre -->
                        <Label text="Titre :" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="form-label" />
                        <TextField fx:id="titreTF" GridPane.rowIndex="0" GridPane.columnIndex="1" styleClass="text-input" editable="false" />

                        <!-- Description -->
                        <Label text="Description :" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="form-label" />
                        <TextArea fx:id="descriptionTA" prefHeight="100" prefWidth="400" GridPane.rowIndex="1" GridPane.columnIndex="1" styleClass="text-input" editable="false" />

                        <!-- Date Début -->
                        <Label text="Date Début :" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="form-label" />
                        <HBox spacing="5" GridPane.rowIndex="2" GridPane.columnIndex="1">
                            <DatePicker fx:id="dateDebutPicker" styleClass="date-input" editable="false" />
                            <Spinner fx:id="heureDebutSpinner" prefWidth="60" styleClass="time-input" editable="false" />
                            <Label text=":" styleClass="time-separator" />
                            <Spinner fx:id="minuteDebutSpinner" prefWidth="60" styleClass="time-input" editable="false" />
                        </HBox>

                        <!-- Date Fin -->
                        <Label text="Date Fin :" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="form-label" />
                        <HBox spacing="5" GridPane.rowIndex="3" GridPane.columnIndex="1">
                            <DatePicker fx:id="dateFinPicker" styleClass="date-input" editable="false" />
                            <Spinner fx:id="heureFinSpinner" prefWidth="60" styleClass="time-input" editable="false" />
                            <Label text=":" styleClass="time-separator" />
                            <Spinner fx:id="minuteFinSpinner" prefWidth="60" styleClass="time-input" editable="false" />
                        </HBox>

                        <!-- Organisateur -->
                        <Label text="Organisateur :" GridPane.rowIndex="4" GridPane.columnIndex="0" styleClass="form-label" />
                        <TextField fx:id="organisateurField" GridPane.rowIndex="4" GridPane.columnIndex="1" styleClass="text-input" editable="false" />

                        <!-- Carte -->
                        <Label text="Carte :" GridPane.rowIndex="5" GridPane.columnIndex="0" styleClass="form-label" />
                        <WebView fx:id="mapWebView" prefHeight="200" prefWidth="400" minHeight="200" minWidth="400" GridPane.rowIndex="5" GridPane.columnIndex="1" styleClass="map-view" />

                        <!-- Adresse -->
                        <Label text="Adresse :" GridPane.rowIndex="6" GridPane.columnIndex="0" styleClass="form-label" />
                        <TextField fx:id="adresseField" GridPane.rowIndex="6" GridPane.columnIndex="1" styleClass="text-input" editable="false" />

                        <!-- Coordonnées -->
                        <Label text="Latitude :" GridPane.rowIndex="7" GridPane.columnIndex="0" styleClass="form-label" />
                        <TextField fx:id="latitudeField" GridPane.rowIndex="7" GridPane.columnIndex="1" styleClass="text-input" editable="false" />
                        <Label text="Longitude :" GridPane.rowIndex="8" GridPane.columnIndex="0" styleClass="form-label" />
                        <TextField fx:id="longitudeField" GridPane.rowIndex="8" GridPane.columnIndex="1" styleClass="text-input" editable="false" />

                        <!-- Capacité -->
                        <Label text="Capacité :" GridPane.rowIndex="9" GridPane.columnIndex="0" styleClass="form-label" />
                        <TextField fx:id="capaciteField" GridPane.rowIndex="9" GridPane.columnIndex="1" styleClass="text-input" editable="false" />

                        <!-- Catégorie et Visibilité -->
                        <Label text="Catégorie :" GridPane.rowIndex="10" GridPane.columnIndex="0" styleClass="form-label" />
                        <TextField fx:id="categorieField" GridPane.rowIndex="10" GridPane.columnIndex="1" styleClass="text-input" editable="false" />
                        <Label text="Visibilité :" GridPane.rowIndex="11" GridPane.columnIndex="0" styleClass="form-label" />
                        <TextField fx:id="visibiliteField" GridPane.rowIndex="11" GridPane.columnIndex="1" styleClass="text-input" editable="false" />
                    </GridPane>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>