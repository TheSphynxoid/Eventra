<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.effect.*?>

<AnchorPane xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.thesphynx.controllers.ParticipantController">
    <VBox spacing="20" alignment="TOP_CENTER" style="-fx-background-color: #f5f5f5; -fx-padding: 30;">
        <!-- Titre -->
        <Label text="Liste des Événements disponibles" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

        <!-- Contrôles de recherche -->
        <HBox spacing="10" alignment="CENTER">
            <ComboBox fx:id="cbCategories" promptText="Toutes les catégories" style="-fx-pref-width: 200;"/>
            <Button text="Filtrer" onAction="#filtrerParCategorie" style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
            <Button text="Réinitialiser" onAction="#reinitialiserFiltre" style="-fx-background-color: #95a5a6; -fx-text-fill: white;"/>
        </HBox>

        <!-- Tableau des événements -->
        <TableView fx:id="tvEvenements" style="-fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
            <columns>
                <TableColumn fx:id="colTitre" text="Titre" prefWidth="150"/>
                <TableColumn fx:id="colDescription" text="Description" prefWidth="200"/>
                <TableColumn fx:id="colDateDebut" text="Date Début" prefWidth="150"/>
                <TableColumn fx:id="colDateFin" text="Date Fin" prefWidth="150"/>
                <TableColumn fx:id="colAdresse" text="Adresse" prefWidth="200"/>
                <TableColumn fx:id="colCategorie" text="Catégorie" prefWidth="100"/>
                <TableColumn fx:id="colVisibilite" text="Visibilité" prefWidth="100"/>
                <TableColumn fx:id="colCapacite" text="Capacité" prefWidth="80"/>
                <TableColumn fx:id="colActions" text="Actions" prefWidth="100"/>
            </columns>
        </TableView>

        <!-- Bouton Retour -->
        <Button text="Retour" onAction="#retourAccueil" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-width: 120; -fx-pref-height: 35;"/>
    </VBox>
</AnchorPane>