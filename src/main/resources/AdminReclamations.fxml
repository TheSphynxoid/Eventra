<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="org.example.controllers.AdminReclamationsController"
            prefWidth="900" prefHeight="600">
    <children>
        <VBox spacing="10" AnchorPane.topAnchor="10" AnchorPane.leftAnchor="10" AnchorPane.rightAnchor="10" AnchorPane.bottomAnchor="10"
              style="-fx-background-color: #F7F9FC; -fx-padding: 15;">

            <!-- Titre -->
            <Label text="Réclamations des utilisateurs"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #263238;" />

            <!-- Statistiques -->
            <HBox spacing="30" alignment="CENTER_LEFT" style="-fx-padding: 10;">
                <Label fx:id="totalLabel" text="Total : 0" style="-fx-font-weight: bold;" />
                <Label fx:id="traiteLabel" text="Traitées : 0" style="-fx-font-weight: bold; -fx-text-fill: #2E7D32;" />
                <Label fx:id="encoursLabel" text="En cours : 0" style="-fx-font-weight: bold; -fx-text-fill: #F57C00;" />
            </HBox>

            <!-- 🔎 Zone de recherche et de filtre -->
            <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 10;">
                <Label text="Rechercher :" />
                <TextField fx:id="searchField" promptText="Email, Type, Description..."
                           style="-fx-background-color: white; -fx-border-color: #90A4AE; -fx-border-radius: 4; -fx-padding: 6;" />

                <Label text="État :" />
                <ComboBox fx:id="etatFilter" promptText="Tous les états"
                          style="-fx-background-color: white; -fx-border-color: #90A4AE; -fx-border-radius: 4; -fx-padding: 6;" />
            </HBox>

            <!-- 📋 Tableau des réclamations centré -->
            <HBox alignment="CENTER">
                <TableView fx:id="tableReclamations" prefHeight="420" maxWidth="850"
                           style="-fx-background-color: white; -fx-border-color: #CFD8DC; -fx-border-radius: 6; -fx-padding: 8;">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="50" />
                        <TableColumn fx:id="colClient" text="ID Client" prefWidth="100" />
                        <TableColumn fx:id="colEmail" text="Email" prefWidth="180" />
                        <TableColumn fx:id="colType" text="Type" prefWidth="120" />
                        <TableColumn fx:id="colDescription" text="Description" prefWidth="200" />
                        <TableColumn fx:id="colDate" text="Date" prefWidth="120" />
                        <TableColumn fx:id="colEtat" text="État" prefWidth="100" />
                        <TableColumn fx:id="colAction" text="Action" prefWidth="100" />
                    </columns>
                </TableView>
            </HBox>

            <Separator />

            <!-- 📄 Informations utilisateur -->
            <VBox spacing="8" style="-fx-background-color: #ECEFF1; -fx-border-color: #CFD8DC; -fx-border-radius: 4; -fx-padding: 10;" fx:id="userInfoBox">
                <Label text="📋 Informations utilisateur sélectionné :" style="-fx-font-weight: bold;" />
                <Label fx:id="infoEmail" text="Email : -" />
                <Label fx:id="infoClientId" text="ID Client : -" />
                <Label fx:id="infoTotalRec" text="Nombre total de réclamations : -" />
                <Label fx:id="infoDerniereDate" text="Date de dernière réclamation : -" />
            </VBox>

        </VBox>
    </children>
</AnchorPane>
