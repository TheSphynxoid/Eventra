<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="org.example.controllers.RepondreReclamationController"
            prefWidth="600" prefHeight="400" style="-fx-background-color: #F5F5F5; -fx-padding: 20;">
    <children>
        <VBox spacing="15" AnchorPane.topAnchor="20" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20">

            <!-- Titre -->
            <Label text="Répondre à la Réclamation"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #37474F; -fx-alignment: center;" />

            <!-- Email de l'utilisateur -->
            <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 5px;">
                <Label text="Email utilisateur :"
                       style="-fx-font-size: 14px; -fx-text-fill: #212121; -fx-font-weight: bold;" />
                <Label fx:id="emailLabel" text="-" style="-fx-font-size: 14px; -fx-text-fill: #1976D2;"/>
            </HBox>


            <!-- Zone de saisie pour la réponse -->
            <TextArea fx:id="reponseTextArea" promptText="Écrivez votre réponse ici..."
                      style="-fx-background-color: white; -fx-border-color: #90A4AE; -fx-border-radius: 6; -fx-padding: 10; -fx-font-size: 14px;" />

            <!-- Boutons -->
            <HBox spacing="20" alignment="CENTER_RIGHT" style="-fx-padding: 10;">
                <Button text="Envoyer"
                        style="-fx-background-color: #1976D2; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 10 20;"
                        fx:id="envoyerReponse" onAction="#envoyerReponse" />
                <Button text="Fermer" style="-fx-background-color: #B0BEC5; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 10 20;"
                        fx:id="fermer" onAction="#fermer"/>

            </HBox>
        </VBox>
    </children>
</AnchorPane>
