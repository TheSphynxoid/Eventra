<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefHeight="600" prefWidth="800" spacing="10" style="-fx-background-color: #f0f0f0;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllers.SponsorDemandeListController">

    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <Label style="-fx-text-fill: #0078D7;" text="Sponsorship Requests">
        <font>
            <Font name="System Bold" size="24" />
        </font>
    </Label>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <ComboBox fx:id="filterStatusComboBox" prefWidth="200" promptText="Filter by Status" />
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#refreshButtonClicked" style="-fx-background-color: #0078D7; -fx-text-fill: white;" text="Refresh" />
    </HBox>

    <TableView fx:id="demandeTableView" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idColumn" prefWidth="50" text="ID" />
            <TableColumn fx:id="eventColumn" prefWidth="100" text="Event" />
            <TableColumn fx:id="sponsorColumn" prefWidth="100" text="Sponsor" />
            <TableColumn fx:id="montantColumn" prefWidth="100" text="Amount" />
            <TableColumn fx:id="statusColumn" prefWidth="100" text="Status" />
            <TableColumn fx:id="dateCreationColumn" prefWidth="120" text="Created On" />
            <TableColumn fx:id="dateAcceptanceColumn" prefWidth="120" text="Accepted On" />
            <TableColumn fx:id="actionsColumn" prefWidth="150" text="Actions" />
        </columns>
    </TableView>

    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button onAction="#viewDetailsButtonClicked" style="-fx-background-color: #0078D7; -fx-text-fill: white;" text="View Details" />
    </HBox>

</VBox>
