<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefHeight="429.0" prefWidth="496.0" spacing="10" style="-fx-background-color: #f0f0f0;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllers.AddSponsorDemandeController">

    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <Label style="-fx-text-fill: #0078D7;" text="New Sponsorship Request">
        <font>
            <Font name="System Bold" size="20" />
        </font>
    </Label>

    <GridPane hgap="10" vgap="10">
        <Label text="Event ID:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <TextField fx:id="eventIdField" GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <Label text="Amount (DT):" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <TextField fx:id="amountField" GridPane.columnIndex="1" GridPane.rowIndex="1" />

        <Label prefHeight="18.0" prefWidth="174.0" text="Description:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <TextArea fx:id="descriptionField" prefHeight="169.0" prefRowCount="4" prefWidth="362.0" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="2" />
      <columnConstraints>
         <ColumnConstraints maxWidth="86.4" minWidth="75.4" prefWidth="83.4" />
         <ColumnConstraints maxWidth="369.4" minWidth="358.4" prefWidth="361.4" />
      </columnConstraints>
      <rowConstraints>
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
      </rowConstraints>
    </GridPane>

    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button onAction="#handleCancel" style="-fx-background-color: #E81123; -fx-text-fill: white;" text="Cancel" />
        <Button onAction="#handleSubmit" style="-fx-background-color: #107C10; -fx-text-fill: white;" text="Submit" />
    </HBox>

</VBox>
